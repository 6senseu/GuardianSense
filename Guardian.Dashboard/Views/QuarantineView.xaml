<UserControl x:Class="Guardian.Dashboard.Views.QuarantineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Quarantine" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="Refresh" Width="100" Command="{Binding LoadCommand}" Margin="0,0,8,0"/>
            <Button Content="Restore" Width="100" Command="{Binding RestoreCommand}" Margin="0,0,8,0"/>
            <Button Content="Delete" Width="100" Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
            <Button Content="Open in Sandbox" Width="140" Command="{Binding OpenInSandboxCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Records}"
                  SelectedItem="{Binding SelectedRecord}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*"/>
                <DataGridTextColumn Header="Quarantined" Binding="{Binding QuarantinedAtUtc, StringFormat='{}{0:g}'}" Width="140"/>
                <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="90"/>
                <DataGridTextColumn Header="Score" Binding="{Binding RiskScore}" Width="60"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="DarkSlateGray"/>
    </Grid>
</UserControl>
