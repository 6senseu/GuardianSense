<Window x:Class="Guardian.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Guardian.Dashboard.Views"
        mc:Ignorable="d"
        Title="GuardianSense Dashboard" Height="640" Width="960">
    <TabControl>
        <TabItem Header="Status">
            <views:StatusView DataContext="{Binding Status}"/>
        </TabItem>
        <TabItem Header="Reports">
            <views:ReportsView DataContext="{Binding Reports}"/>
        </TabItem>
        <TabItem Header="Quarantine">
            <views:QuarantineView DataContext="{Binding Quarantine}"/>
        </TabItem>
        <TabItem Header="Settings">
            <views:SettingsView DataContext="{Binding Settings}"/>
        </TabItem>
    </TabControl>
</Window>
